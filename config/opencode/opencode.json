{
  "$schema": "https://opencode.ai/config.json",
  "model": "agent-plan/glm-5.2",
  "provider": {
    "agent-plan": {
      "name": "agent-plan",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "YOUR_API_KEY_HERE",
        "baseURL": "https://ark.cn-beijing.volces.com/api/plan/v3"
      },
      "models": {
        "glm-5.2": {
          "name": "glm-5.2",
          "limit": {
            "context": 1048576,
            "output": 16384
          }
        }
      }
    }
  },
  "mcp": {
    "exa": {
      "url": "https://mcp.exa.ai/mcp",
      "type": "remote",
      "enabled": true
    }
  }
}
